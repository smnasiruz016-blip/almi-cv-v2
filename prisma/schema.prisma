generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum DocumentStatus {
  DRAFT
  READY
  ARCHIVED
}

enum TemplateTier {
  FREE
  PREMIUM
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  passwordHash     String
  role             UserRole         @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)
  sessions         Session[]
  resumes          Resume[]
  chatMessages     ChatMessage[]

  // Stripe subscription state — kept in lockstep with subscriptionTier by webhook.
  stripeCustomerId              String?   @unique
  stripeSubscriptionId          String?   @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean   @default(false)
  trialEndsAt                   DateTime?

  // AI usage tracking (free-tier quota).
  aiCallsThisMonth Int       @default(0)
  aiCallsResetAt   DateTime?

  // Comp Pro access — granted by owner for beta testers / dogfooding.
  // Independent of Stripe state; isProActive() short-circuits true when
  // compProUntil is in the future, even if subscriptionStatus is null.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Marketing opt-in — set explicitly via the review form's checkbox or any
  // future newsletter widget. Audit trail via marketingOptInAt.
  marketingOptIn   Boolean   @default(false)
  marketingOptInAt DateTime?

  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Resume {
  id           String         @id @default(cuid())
  userId       String
  title        String         @default("Untitled CV")
  templateKey  String         @default("brand-essence")
  templateTier TemplateTier   @default(FREE)
  status       DocumentStatus @default(DRAFT)
  draftData    Json?
  template     String         @default("classic-serif")
  data         Json           @default("{}")
  isDraft      Boolean        @default(true)
  lastSnapshot   Json?
  lastSnapshotAt DateTime?
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverLetters CoverLetter[]
  chatMessages ChatMessage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, isDraft])
}

model CoverLetter {
  id             String   @id @default(cuid())
  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title          String   @default("Untitled cover letter")
  jobDescription String
  hiringManager  String?
  tone           String   @default("confident")
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([resumeId, updatedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvId      String?
  resume    Resume?  @relation(fields: [cvId], references: [id], onDelete: SetNull)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([cvId])
}

// Stripe webhook idempotency. Stripe retries are normal — by storing the
// event id we make sure we only mutate user state once per event.
model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String   @db.Text
  improvement String?  @db.Text
  displayName String?
  showOnSite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([showOnSite, createdAt])
  @@index([userId])
}

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String    @default("homepage")
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  ipAddress      String?
  userAgent      String?

  @@index([email])
  @@index([subscribedAt])
}
