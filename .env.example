# Comma-separated list of admin emails. Drives both isOwner() (used by
# /admin/comp-accounts and /admin/reviews) and requireFounder() (used by
# /admin/template-studio). Empty or unset = no admin access.
OWNER_EMAILS=""

# Monthly cap for Anthropic API spend in the Template Studio (USD).
# Defaults to 20 if unset or unparseable. canGenerate() refuses
# generation once cumulative monthly cost would exceed this; warns at
# 80%. Resets on the 1st of each calendar month (UTC).
STUDIO_MONTHLY_BUDGET_USD="20"
